{
  "name": "hash_tool_rs",
  "private": true,
  "type": "module",
  "scripts": {
    "css:build": "bunx @tailwindcss/cli -i ./style/tailwind.css -o ./style/app.css --minify",
    "css:watch": "bunx @tailwindcss/cli -i ./style/tailwind.css -o ./style/app.css --watch",
    "dev": "bun run css:watch & cargo leptos watch",
    "build": "bun run css:build && cargo leptos build --release"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.8",
    "tailwindcss": "^4.1.8"
  }
}
